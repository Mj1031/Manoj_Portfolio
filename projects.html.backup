<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Education &amp; Projects | MJ Portfolio</title>
    <meta name="description" content="GitHub projects by Manoj Ganeshe — dashboards, data analysis, and business intelligence systems.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="futuristic.css">
    <!-- Vanta -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"></script>
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <!-- Lucide -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'futuristic-blue':   '#00d2ff',
                        'futuristic-purple': '#9d50bb',
                        'space-black':       '#030305',
                        'space-grey':        '#121214',
                    }
                }
            }
        }
    </script>
    <style>
        /* ── Project card icon color cycling ── */
        .repo-icon-0  { color: #00d2ff; }   /* blue */
        .repo-icon-1  { color: #9d50bb; }   /* purple */
        .repo-icon-2  { color: #00ffc8; }   /* teal */
        .repo-icon-3  { color: #ff7b54; }   /* orange */
        .repo-icon-4  { color: #f9ca24; }   /* yellow */
        .repo-icon-5  { color: #e0145e; }   /* red */
        .repo-icon-6  { color: #a8edea; }   /* mint */
        .repo-icon-7  { color: #fd79a8; }   /* pink */

        .repo-glow-0  { background: rgba(0, 210, 255, 0.12); }
        .repo-glow-1  { background: rgba(157, 80, 187, 0.12); }
        .repo-glow-2  { background: rgba(0, 255, 200, 0.10); }
        .repo-glow-3  { background: rgba(255, 123, 84, 0.12); }
        .repo-glow-4  { background: rgba(249, 202, 36, 0.10); }
        .repo-glow-5  { background: rgba(224, 20, 94, 0.12); }
        .repo-glow-6  { background: rgba(168, 237, 234, 0.10); }
        .repo-glow-7  { background: rgba(253, 121, 168, 0.12); }

        .repo-border-0:hover { border-color: rgba(0, 210, 255, 0.40) !important; }
        .repo-border-1:hover { border-color: rgba(157, 80, 187, 0.40) !important; }
        .repo-border-2:hover { border-color: rgba(0, 255, 200, 0.40) !important; }
        .repo-border-3:hover { border-color: rgba(255, 123, 84, 0.40) !important; }
        .repo-border-4:hover { border-color: rgba(249, 202, 36, 0.40) !important; }
        .repo-border-5:hover { border-color: rgba(224, 20, 94, 0.40) !important; }
        .repo-border-6:hover { border-color: rgba(168, 237, 234, 0.40) !important; }
        .repo-border-7:hover { border-color: rgba(253, 121, 168, 0.40) !important; }

        /* Loading skeleton pulse */
        .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 12px;
        }
        @keyframes shimmer {
            0%   { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* GitHub badge */
        .github-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-family: 'Orbitron', monospace;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 4px 10px;
            border-radius: 99px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.10);
            color: #9ca3af;
            transition: all 0.3s ease;
        }
        .github-badge:hover {
            background: rgba(255,255,255,0.10);
            color: white;
        }

        /* Stat chip */
        .stat-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 10px;
            color: #6b7280;
            font-family: monospace;
        }

        /* Updated dot */
        .updated-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: #10b981;
            display: inline-block;
            margin-right: 4px;
            box-shadow: 0 0 6px rgba(16,185,129,0.6);
        }

        /* Filter buttons */
        .filter-btn {
            font-family: 'Orbitron', sans-serif;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 6px 16px;
            border-radius: 99px;
            border: 1px solid rgba(255,255,255,0.10);
            background: transparent;
            color: #9ca3af;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .filter-btn:hover,
        .filter-btn.active {
            background: rgba(0,210,255,0.12);
            border-color: rgba(0,210,255,0.35);
            color: #00d2ff;
        }

        /* Empty state */
        #empty-state { display: none; }

        /* Project count badge */
        .count-badge {
            display: inline-block;
            background: rgba(0,210,255,0.15);
            border: 1px solid rgba(0,210,255,0.25);
            color: #00d2ff;
            font-size: 10px;
            font-family: 'Orbitron', monospace;
            padding: 2px 10px;
            border-radius: 99px;
            vertical-align: middle;
            margin-left: 10px;
        }
    </style>
</head>
<body class="bg-space-black text-white font-['Inter'] selection:bg-futuristic-blue/30">
    <div id="vanta-canvas"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 px-6 py-4 glass border-b border-white/10 backdrop-blur-xl">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <a href="index.html" class="text-3xl font-orbitron font-black gradient-text tracking-tighter mj-logo-glow">MJ</a>
                <div class="h-8 w-[1px] bg-white/20 hidden md:block"></div>
                <span class="text-xs font-orbitron uppercase tracking-widest text-futuristic-blue hidden md:block">Business Analyst</span>
            </div>
            
            <div class="hidden md:flex items-center gap-8">
                <a href="index.html"      class="text-sm font-medium hover:text-futuristic-blue transition-colors uppercase tracking-widest font-orbitron text-gray-400">Home</a>
                <a href="experience.html" class="text-sm font-medium hover:text-futuristic-blue transition-colors uppercase tracking-widest font-orbitron text-gray-400">Experience</a>
                <a href="projects.html"   class="text-sm font-medium uppercase tracking-widest font-orbitron text-futuristic-blue border-b border-futuristic-blue">Projects</a>
                <a href="skills.html"     class="text-sm font-medium hover:text-futuristic-blue transition-colors uppercase tracking-widest font-orbitron text-gray-400">Skills</a>
                <a href="contact.html"    class="px-5 py-2 glass border-futuristic-blue/30 text-xs font-bold uppercase tracking-widest font-orbitron hover:bg-futuristic-blue/10 transition-all">Contact</a>
            </div>

            <button class="md:hidden text-white" id="menu-toggle"><i data-lucide="menu"></i></button>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed inset-0 z-40 bg-space-black/95 backdrop-blur-2xl hidden flex-col items-center justify-center gap-8 p-10">
        <button class="absolute top-6 right-6 text-white" id="menu-close"><i data-lucide="x"></i></button>
        <a href="index.html"      class="text-2xl font-orbitron uppercase tracking-widest">Home</a>
        <a href="experience.html" class="text-2xl font-orbitron uppercase tracking-widest">Experience</a>
        <a href="projects.html"   class="text-2xl font-orbitron uppercase tracking-widest text-futuristic-blue">Projects</a>
        <a href="skills.html"     class="text-2xl font-orbitron uppercase tracking-widest">Skills</a>
        <a href="contact.html"    class="text-2xl font-orbitron uppercase tracking-widest">Contact</a>
    </div>

    <main class="relative pt-32 pb-32 px-6 min-h-screen">

        <!-- ── Page Header ── -->
        <section class="max-w-7xl mx-auto mb-16" id="page-header">
            <p class="text-xs font-orbitron uppercase tracking-[0.6em] text-futuristic-blue mb-3">Academic &amp; Applied</p>
            <h1 class="text-5xl md:text-7xl font-orbitron font-black uppercase mb-6">
                Education &amp; Projects <span id="repo-count-badge" class="count-badge hidden">0</span>
            </h1>
            <p class="text-gray-400 font-light tracking-wide max-w-2xl text-sm leading-relaxed">
                My academic foundation paired with a live feed of GitHub projects spanning business intelligence dashboards, data management systems, and analytics.
            </p>
        </section>

        <!-- ── Education Section ── -->
        <section class="max-w-7xl mx-auto mb-24">
            <div class="flex items-center gap-4 mb-10">
                <div class="h-[1px] flex-grow bg-white/10"></div>
                <h3 class="text-sm font-orbitron font-bold uppercase tracking-[0.4em] text-gray-500">Education</h3>
                <div class="h-[1px] flex-grow bg-white/10"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="glass p-10 glass-card relative overflow-hidden group">
                    <div class="absolute -right-8 -bottom-8 opacity-5 group-hover:opacity-10 transition-opacity duration-500">
                        <i data-lucide="graduation-cap" class="w-40 h-40"></i>
                    </div>
                    <div class="flex flex-col gap-4 relative z-10">
                        <span class="text-[10px] font-orbitron text-futuristic-purple uppercase tracking-widest">M.S. Degree</span>
                        <h4 class="text-2xl font-orbitron font-black leading-tight text-white">Engineering &amp; Operations Management</h4>
                        <p class="text-gray-400 font-light tracking-wide">University of New Haven</p>
                        <p class="text-gray-500 text-xs italic">Aug 2022 – May 2024 · West Haven, CT</p>
                        <div class="flex gap-2 flex-wrap mt-2">
                            <span class="github-badge">Ops Strategy</span>
                            <span class="github-badge">Data-Driven Mgmt</span>
                            <span class="github-badge">Process Optimization</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── GitHub Projects ── -->
        <section class="max-w-7xl mx-auto">
            <div class="flex items-center gap-4 mb-6">
                <div class="h-[1px] flex-grow bg-white/10"></div>
                <h3 class="text-sm font-orbitron font-bold uppercase tracking-[0.4em] text-gray-500">GitHub Repositories</h3>
                <div class="h-[1px] flex-grow bg-white/10"></div>
            </div>

            <!-- Filter Bar -->
            <div class="flex flex-wrap gap-2 mb-10" id="filter-bar">
                <button class="filter-btn active" data-filter="all" onclick="filterRepos('all', this)">All</button>
                <button class="filter-btn" data-filter="tableau" onclick="filterRepos('tableau', this)">Tableau</button>
                <button class="filter-btn" data-filter="powerbi" onclick="filterRepos('powerbi', this)">Power BI</button>
                <button class="filter-btn" data-filter="sql" onclick="filterRepos('sql', this)">SQL / DB</button>
                <button class="filter-btn" data-filter="management" onclick="filterRepos('management', this)">Management</button>
            </div>

            <!-- Loading skeletons -->
            <div id="loading-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="skeleton h-72"></div>
                <div class="skeleton h-72"></div>
                <div class="skeleton h-72"></div>
                <div class="skeleton h-72"></div>
                <div class="skeleton h-72 hidden md:block"></div>
                <div class="skeleton h-72 hidden lg:block"></div>
            </div>

            <!-- Live repos grid -->
            <div id="repos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 hidden"></div>

            <!-- Empty state -->
            <div id="empty-state" class="text-center py-20 text-gray-600 font-orbitron uppercase tracking-widest text-sm">
                No matching repositories
            </div>

            <!-- Error state -->
            <div id="error-state" class="hidden text-center py-20">
                <i data-lucide="wifi-off" class="w-12 h-12 text-gray-600 mx-auto mb-4"></i>
                <p class="font-orbitron uppercase tracking-widest text-sm text-gray-500 mb-2">Unable to load GitHub repos</p>
                <p class="text-xs text-gray-600">Check your connection or try refreshing the page.</p>
            </div>
        </section>
    </main>

    <footer class="py-20 border-t border-white/5 text-center px-6">
        <div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
            <div class="text-4xl font-orbitron font-black gradient-text tracking-tighter mj-logo-glow">MJ</div>
            <p class="text-xs font-orbitron uppercase tracking-[0.3em] text-gray-500">
                &copy; 2026 MJ &middot; AI Powered Business Intelligence
            </p>
        </div>
    </footer>

    <script>
        lucide.createIcons();

        // ── Vanta ──
        VANTA.NET({
            el: "#vanta-canvas",
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200,
            minWidth: 200,
            scale: 1,
            scaleMobile: 1,
            color: 0x00d2ff,
            backgroundColor: 0x030305,
            points: 12,
            maxDistance: 24,
            spacing: 15
        });

        // ── GSAP ──
        gsap.registerPlugin(ScrollTrigger);
        gsap.from("#page-header", { y: 40, opacity: 0, duration: 1.2, ease: "power3.out" });

        // ── Mobile Menu ──
        document.getElementById('menu-toggle').addEventListener('click', () =>
            document.getElementById('mobile-menu').classList.remove('hidden'));
        document.getElementById('menu-close').addEventListener('click', () =>
            document.getElementById('mobile-menu').classList.add('hidden'));

        // ── Icon mapping based on repo name keywords ──
        function getRepoMeta(repo) {
            const name = (repo.name + ' ' + (repo.description || '')).toLowerCase();
            if (name.includes('tableau'))        return { icon: 'bar-chart-2',    tags: ['Tableau', 'Data Viz', 'Dashboard'] };
            if (name.includes('powerbi'))        return { icon: 'pie-chart',      tags: ['Power BI', 'Dashboard', 'Analytics'] };
            if (name.includes('hospital'))       return { icon: 'activity',       tags: ['SQL', 'DBMS', 'ETL', 'Healthcare'] };
            if (name.includes('nav') || name.includes('project-management')) return { icon: 'kanban', tags: ['Project Mgmt', 'Agile', 'Workflow'] };
            if (name.includes('hr'))             return { icon: 'users',          tags: ['HR', 'Power BI', 'Analytics'] };
            if (name.includes('covid') || name.includes('c19')) return { icon: 'trending-up', tags: ['Tableau', 'Public Health', 'Data'] };
            if (name.includes('layoff') || name.includes('ld'))  return { icon: 'layout-dashboard', tags: ['Tableau', 'Azure SQL', 'ETL'] };
            if (name.includes('student') || name.includes('isd')) return { icon: 'globe',     tags: ['Tableau', 'Demographics', 'Analytics'] };
            return { icon: 'code-2', tags: [] };
        }

        // ── Humanize repo name ──
        function humanizeName(name) {
            // Handle special cases first
            const specialCases = {
                'NAV-Project-Management': 'NAV Project Management',
                'Tableau-C19': 'Tableau COVID-19 Dashboard',
                'PowerBI-CC': 'Power BI Call Center',
                'PowerBI-HR': 'Power BI HR Analytics',
                'Tableau-LD': 'Tableau Layoff Demographics',
                'Tableau-ISD': 'Tableau International Student Demographics',
                'Hospital-Management-System': 'Hospital Management System'
            };

            if (specialCases[name]) {
                return specialCases[name];
            }

            // Generic formatting for any other repos
            return name
                .replace(/-/g, ' ')
                .replace(/([A-Z])/g, ' $1')
                .replace(/\s+/g, ' ')
                .trim();
        }

        // ── Format date relative ──
        function relativeDate(iso) {
            const diff = (Date.now() - new Date(iso)) / 1000;
            if (diff < 60)        return 'just now';
            if (diff < 3600)      return Math.floor(diff/60) + 'm ago';
            if (diff < 86400)     return Math.floor(diff/3600) + 'h ago';
            if (diff < 2592000)   return Math.floor(diff/86400) + 'd ago';
            if (diff < 31104000)  return Math.floor(diff/2592000) + 'mo ago';
            return Math.floor(diff/31104000) + 'yr ago';
        }

        // ── Build card HTML ──
        function buildCard(repo, idx) {
            const meta   = getRepoMeta(repo);
            const cycle  = idx % 8;
            const title  = humanizeName(repo.name);
            const desc   = repo.description || 'No description provided.';
            const tags   = meta.tags;
            const upd    = relativeDate(repo.updated_at);

            const tagHTML = tags.map(t =>
                `<span class="github-badge">${t}</span>`
            ).join('');

            const starsHTML = repo.stargazers_count > 0
                ? `<span class="stat-chip"><i data-lucide="star" style="width:11px;height:11px;"></i> ${repo.stargazers_count}</span>` : '';
            const forksHTML = repo.forks_count > 0
                ? `<span class="stat-chip"><i data-lucide="git-fork" style="width:11px;height:11px;"></i> ${repo.forks_count}</span>` : '';
            const langHTML  = repo.language
                ? `<span class="stat-chip"><span style="width:8px;height:8px;border-radius:50%;background:#00d2ff;display:inline-block;margin-right:3px;"></span>${repo.language}</span>` : '';

            // Filter keywords for data attr
            const filterKeys = [
                (repo.name.toLowerCase().includes('tableau') ? 'tableau' : ''),
                (repo.name.toLowerCase().includes('powerbi') ? 'powerbi' : ''),
                (repo.name.toLowerCase().includes('hospital') || repo.name.toLowerCase().includes('nav') ? 'sql' : ''),
                (repo.name.toLowerCase().includes('nav') || repo.name.toLowerCase().includes('hospital') ? 'management' : ''),
            ].filter(Boolean).join(' ') || 'all';

            // Check if screenshot exists
            const hasScreenshot = repo.screenshot;

            return `
            <div class="glass glass-card flex flex-col gap-0 group repo-border-${cycle} transition-all duration-300 overflow-hidden"
                 style="border: 1px solid rgba(255,255,255,0.08);"
                 data-filter="${filterKeys} all">

                <!-- Screenshot/Icon area -->
                ${hasScreenshot ? `
                <div class="relative overflow-hidden repo-glow-${cycle}"
                     style="border-bottom: 1px solid rgba(255,255,255,0.06); height: 200px;">
                    <img src="${repo.screenshot}"
                         alt="${title} screenshot"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                         onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\\'flex items-center justify-center h-full repo-glow-${cycle}\\'><i data-lucide=\\'${meta.icon}\\' class=\\'repo-icon-${cycle} w-14 h-14\\'></i></div>'; lucide.createIcons();" />
                    <div class="absolute inset-0 bg-gradient-to-t from-space-black/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
                </div>
                ` : `
                <div class="relative flex items-center justify-center repo-glow-${cycle} py-10 overflow-hidden"
                     style="border-bottom: 1px solid rgba(255,255,255,0.06);">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                         style="background: radial-gradient(circle at center, rgba(0,210,255,0.08) 0%, transparent 70%);"></div>
                    <i data-lucide="${meta.icon}" class="repo-icon-${cycle} w-14 h-14 group-hover:scale-110 transition-transform duration-500 relative z-10"></i>
                </div>
                `}

                <!-- Content -->
                <div class="flex flex-col gap-4 p-7 flex-1">
                    <div>
                        <h4 class="text-lg font-orbitron font-bold text-white leading-snug mb-2">${title}</h4>
                        <p class="text-gray-500 text-xs font-light leading-relaxed">${desc}</p>
                    </div>

                    <div class="flex flex-wrap gap-1.5">${tagHTML}</div>

                    <div class="mt-auto pt-4 flex items-center justify-between border-t border-white/5">
                        <div class="flex items-center gap-3">
                            ${starsHTML}${forksHTML}${langHTML}
                            <span class="stat-chip"><span class="updated-dot"></span>${upd}</span>
                        </div>
                        <a href="${repo.html_url}" target="_blank" rel="noopener"
                           class="github-badge hover:text-futuristic-blue hover:border-futuristic-blue/40">
                            <i data-lucide="github" style="width:11px;height:11px;"></i> View
                        </a>
                    </div>
                </div>
            </div>`;
        }

        // ── All loaded repos (global) ──
        let allCards = [];

        // ── Filter ──
        function filterRepos(filter, btn) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const grid = document.getElementById('repos-grid');
            const cards = grid.querySelectorAll('[data-filter]');
            let visible = 0;
            cards.forEach(card => {
                const matches = filter === 'all' || card.dataset.filter.includes(filter);
                card.style.display = matches ? '' : 'none';
                if (matches) visible++;
            });
            document.getElementById('empty-state').style.display = visible === 0 ? 'block' : 'none';
        }

        // ── Fallback project data ──
        const FALLBACK_REPOS = [
            {
                name: 'NAV-Project-Management',
                description: 'Welcome to the NAV Solutions Project Management System! This system is designed to streamline project management processes for NAV Solutions, a software development company specializing in end-to-end solutions for clients like Michael Kors, Netflix, and other corporations.',
                html_url: 'https://github.com/Mj1031/NAV-Project-Management',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:20:57Z',
                screenshot: 'images/projects/nav-project.png'
            },
            {
                name: 'Tableau-C19',
                description: 'Covid 19 Dashboard',
                html_url: 'https://github.com/Mj1031/Tableau-C19',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:15:03Z',
                screenshot: 'images/projects/tableau-c19.png'
            },
            {
                name: 'PowerBI-CC',
                description: 'Call Center Dashboard',
                html_url: 'https://github.com/Mj1031/PowerBI-CC',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:14:25Z',
                screenshot: 'images/projects/powerbi-cc.png'
            },
            {
                name: 'PowerBI-HR',
                description: 'HR Data Dashboard',
                html_url: 'https://github.com/Mj1031/PowerBI-HR',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:12:45Z',
                screenshot: 'images/projects/powerbi-hr.png'
            },
            {
                name: 'Tableau-LD',
                description: 'Layoff Demographics Project',
                html_url: 'https://github.com/Mj1031/Tableau-LD',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:11:06Z',
                screenshot: 'images/projects/tableau-ld.png'
            },
            {
                name: 'Tableau-ISD',
                description: 'International Student Demographics',
                html_url: 'https://github.com/Mj1031/Tableau-ISD',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:10:20Z',
                screenshot: 'images/projects/tableau-isd.png'
            },
            {
                name: 'Hospital-Management-System',
                description: 'This is a comprehensive Hospital Management System designed to streamline various operations within a hospital environment. It facilitates efficient management of departments, doctors, patients, medical inventory, payroll, and more.',
                html_url: 'https://github.com/Mj1031/Hospital-Management-System',
                language: null,
                stargazers_count: 0,
                forks_count: 0,
                fork: false,
                updated_at: '2025-03-06T04:09:24Z',
                screenshot: 'images/projects/hospital-mgmt.png'
            }
        ];

        // ── Display repos helper ──
        function displayRepos(repos) {
            document.getElementById('loading-grid').classList.add('hidden');

            if (repos.length === 0) {
                document.getElementById('error-state').classList.remove('hidden');
                return;
            }

            // Count badge
            const badge = document.getElementById('repo-count-badge');
            badge.textContent = repos.length;
            badge.classList.remove('hidden');

            const grid = document.getElementById('repos-grid');
            grid.innerHTML = repos.map((repo, i) => buildCard(repo, i)).join('');
            grid.classList.remove('hidden');

            lucide.createIcons();

            // GSAP stagger on cards
            gsap.from(grid.querySelectorAll('.glass-card'), {
                scrollTrigger: { trigger: grid, start: "top 90%" },
                y: 50, opacity: 0, duration: 0.7,
                stagger: 0.08, ease: "power2.out"
            });
        }

        // ── Fetch GitHub repos ──
        async function loadRepos() {
            const GITHUB_USER = 'Mj1031';
            const EXCLUDE     = [GITHUB_USER.toLowerCase()]; // skip profile readme repo

            try {
                const res  = await fetch(`https://api.github.com/users/${GITHUB_USER}/repos?per_page=100&sort=updated`);
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const repos = await res.json();

                const filtered = repos.filter(r => !EXCLUDE.includes(r.name.toLowerCase()) && !r.fork);

                // Use live data if available
                displayRepos(filtered);

            } catch (err) {
                console.warn('GitHub API unavailable, using fallback data:', err.message);
                // Use fallback data on error (CORS, rate limit, offline, etc.)
                displayRepos(FALLBACK_REPOS);
            }
        }

        loadRepos();
    </script>
</body>
</html>
